{
  "extends": "../../node_modules/expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    
    /* 1. SỬA LỖI: Bỏ qua cảnh báo vàng "deprecated" của baseUrl và moduleResolution */
    "ignoreDeprecations": "6.0",
    
    /* 2. SỬA LỖI: Giúp TypeScript nhận diện được chữ "NodeJS" trong file [id].tsx */
    "types": ["node"],
    
    "paths": {
      "@/*": ["./*"],
      "@/convex/*": ["../../convex/*"] 
    },
    "jsx": "react-native"
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}