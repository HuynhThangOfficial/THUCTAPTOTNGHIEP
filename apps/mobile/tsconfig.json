{
  "extends": "../../node_modules/expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      // Chỉ đường cho TOÀN BỘ những gì bắt đầu bằng @/convex/ 
      // trỏ thẳng ra thư mục convex ở gốc dự án
      "@/convex/*": ["../../convex/*"] 
    },
    "jsx": "react-native"
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}